# ==================================================================
# content-dashboard — Environment Variables (TEMPLATE)
# ------------------------------------------------------------------
# Đây là file MẪU, được commit lên repo. CHỈ chứa placeholder, KHÔNG
# chứa giá trị/secret thật.
# Cách dùng: copy sang `.env` (file mà dotenv tự nạp qua
# `import 'dotenv/config'`) rồi điền giá trị thật. `.env` đã được
# gitignore.
# ==================================================================

# ===== Server (Express) =====
# Cổng API Express. Tùy chọn — code mặc định 4000 nếu bỏ trống.
PORT=4000

# ===== Supabase =====
# URL project Supabase: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# Khóa service_role — CHỈ dùng phía server (đọc/ghi quyền cao).
# Tuyệt đối KHÔNG để lộ ra client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Khóa anon — server trả về client qua /api/config (realtime read-only).
SUPABASE_ANON_KEY=your-anon-key

# ===== Google Sheets (nguồn dữ liệu cho Sync) =====
# ID của Google Spreadsheet nguồn (8 sheet NĐ/QT × Hiếu/Ánh/KA/Liên).
GOOGLE_SHEET_ID=your-google-spreadsheet-id
# --- Credentials Google (GoogleAuthFactory — thứ tự ưu tiên JSON → PATH) ---
# (1) ƯU TIÊN: nội dung Service Account JSON (1 dòng). Dùng cho Railway/cloud —
#     KHÔNG cần file, KHÔNG cần thư mục credentials/. Đặt cả object JSON vào đây.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","...":"..."}
# (2) FALLBACK (máy local): đường dẫn file Service Account JSON (read-only).
#     Mặc định dự án: ./credentials/credentials.json
GOOGLE_CREDENTIALS_PATH=./credentials/credentials.json

# ===== Auto Sync Scheduler (P4 — `npm run scheduler`) =====
# Bật/tắt scheduler. false/0/no → scheduler KHÔNG chạy. Mặc định: true.
SYNC_ENABLED=true
# Lịch cron (5 trường). Mặc định "*/15 * * * *" = 15 phút/lần nếu bỏ trống.
SYNC_CRON=*/15 * * * *
# Khử trùng: xóa content "mồ côi" (có trong DB nhưng không còn trong Sheet) sau mỗi sync.
# Mặc định true. Đặt false để TẮT (chỉ upsert, không xóa). Có guard an toàn chống xóa nhầm.
SYNC_PRUNE_STALE=true

# ===== Content Auto-Sync Webhook (PHASE 12 — POST /api/content-sync) =====
# Secret BẮT BUỘC để gọi webhook. Google Apps Script gửi qua header
# 'x-content-sync-secret' (hoặc body {secret}). CHƯA đặt → webhook bị khóa (503).
# Sinh chuỗi ngẫu nhiên đủ mạnh, KHÔNG commit giá trị thật.
CONTENT_SYNC_SECRET=doi-thanh-mot-chuoi-bi-mat-dai
# Thời gian gộp thay đổi trước khi Sync (ms). Mặc định 60000 = 60 giây.
CONTENT_SYNC_DEBOUNCE_MS=60000
# Trần chờ tối đa kể từ thay đổi đầu tiên (ms). Mặc định 300000 = 5 phút.
CONTENT_SYNC_MAX_WAIT_MS=300000

# ===== Ads Monitor — Import (PHASE 4, `npm run ads:import`) =====
# Spreadsheet RIÊNG của Ads (khác GOOGLE_SHEET_ID của Content).
ADS_SHEET_ID=your-ads-spreadsheet-id
# Tên tab chứa dữ liệu Ads (header: Content · Địa lý · Nhân viên Ads · Mã Page · Amount Spent · Ngày).
ADS_SHEET_TAB=Ads
# PHASE 6 — Go Live: khi ĐÃ cấu hình Supabase, Ads Monitor KHÔNG fallback mock (lỗi sẽ hiện rõ).
# Chỉ đặt ADS_USE_MOCK=true cho môi trường DEV khi muốn ép dùng mock dù đã có Supabase.
# Production: để TRỐNG (mặc định = không dùng mock).
# ADS_USE_MOCK=false

# ===== Ads Monitor — Auto Import Scheduler (`npm run ads:scheduler`) =====
# Chạy nền (worker riêng), tự gọi `ads:import` theo lịch. ĐỘC LẬP với scheduler Content.
# Bật/tắt. false/0/no → KHÔNG chạy. Mặc định: true.
ADS_SYNC_ENABLED=true
# Lịch cron (5 trường). Mặc định "35 9 * * *" = 09:35 mỗi ngày (sau khi Sheet Ads cập nhật 09:20).
ADS_SYNC_CRON=35 9 * * *
